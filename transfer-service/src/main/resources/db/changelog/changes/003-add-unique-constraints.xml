<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-add-unique-constraints" author="system" dbms="postgresql">
        <addUniqueConstraint tableName="accounts"
                             columnNames="account_id"
                             constraintName="uk_accounts_account_id"/>

        <addUniqueConstraint tableName="transactions"
                             columnNames="transaction_id"
                             constraintName="uk_transactions_transaction_id"/>
    </changeSet>

</databaseChangeLog>
